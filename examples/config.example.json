{
    "backup_directory": "/home/<your-username>/onep-backups",
    "formats": [
        "json",
        "md"
    ],
    "encrypt": "age",
    "download_attachments": true,
    "age": {
        "pass_source": "prompt",
        "pass_item": "onep-exporter backup - <your-username>",
        "pass_field": "passphrase",
        "recipients": "",
        "use_yubikey": false,
        "keychain_service": "onep-exporter",
        "keychain_username": "backup",
        "onepassword_vault": null
    }
}